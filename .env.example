# Clerk — https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Clerk Convex integration — https://dashboard.clerk.com/apps/setup/convex
CLERK_FRONTEND_API_URL=https://your-instance.clerk.accounts.dev

# Clerk webhooks — https://dashboard.clerk.com/~/webhooks
# Endpoint URL: {NEXT_PUBLIC_CONVEX_SITE_URL}/clerk-webhook
CLERK_WEBHOOK_SIGNING_SECRET=

# Convex — from https://dashboard.convex.dev (Project → Settings)
CONVEX_DEPLOYMENT=dev:your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Set on Convex deployment as well:
# pnpm exec convex env set CLERK_FRONTEND_API_URL <url>
# pnpm exec convex env set CLERK_WEBHOOK_SIGNING_SECRET <secret>
